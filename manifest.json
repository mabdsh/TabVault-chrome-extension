{
  "manifest_version": 3,
  "name": "TabVault — Tabs & Bookmarks Workspace",
  "version": "1.0.0",
  "description": "Tab manager, bookmark organiser, session saver & broken-link scanner. Groups, suspender, reading list, workspaces, and AI Smart Grouping.",
  "minimum_chrome_version": "114",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "history",
    "storage",
    "unlimitedStorage",
    "alarms",
    "contextMenus",
    "sidePanel",
    "notifications",
    "sessions"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TabVault",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none';"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Open TabVault popup"
    },
    "open-sidebar": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "Open TabVault sidebar"
    },
    "save-session": {
      "description": "Save current session"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/suspended/suspended.html"],
      "matches": ["<all_urls>"]
    }
  ]
}